---
layout: null
---

<?xml version="1.0" encoding="UTF-8"?>
<rss xmlns:itunes="http://www.itunes.com/dtds/podcast-1.0.dtd" 
     xmlns:content="http://purl.org/rss/1.0/modules/content/"
     xmlns:atom="http://www.w3.org/2005/Atom"
     version="2.0">
  <channel>
    <title>{{ site.podcast.title | default: site.title }}</title>
    <link>{{ site.url }}</link>
    <language>{{ site.podcast.language | default: 'en' }}</language>
    <copyright>© {{ site.time | date: '%Y' }} {{ site.title }}</copyright>
    <itunes:author>{{ site.podcast.author | default: site.author }}</itunes:author>
    <description>{{ site.podcast.description | default: site.description }}</description>
    <itunes:type>episodic</itunes:type>
    <itunes:owner>
      <itunes:name>{{ site.author }}</itunes:name>
      <itunes:email>{{ site.email }}</itunes:email>
    </itunes:owner>
    <itunes:image href="{{ site.podcast.artwork | default: '/assets/images/cover-art.jpg' | absolute_url }}"/>
    <itunes:category text="{{ site.podcast.category | default: 'News & Politics' }}"/>
    {% if site.podcast.subcategory %}
    <itunes:category text="{{ site.podcast.subcategory }}"/>
    {% endif %}
    <itunes:explicit>{{ site.podcast.explicit | default: 'false' }}</itunes:explicit>
    <atom:link href="{{ '/feed.xml' | absolute_url }}" rel="self" type="application/rss+xml"/>
    
    {% for post in site.posts %}
    {% if post.categories contains 'podcast' or post.layout == 'podcast' or post.audio_file %}
    <item>
      <title>{{ post.title }}</title>
      <description>{{ post.excerpt | default: post.content | strip_html | truncate: 400 }}</description>
      <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
      <guid isPermaLink="false">{{ post.url | absolute_url }}</guid>
      <link>{{ post.url | absolute_url }}</link>
      {% if post.audio_file %}
      <enclosure url="https://storage.googleapis.com/europe-weekly-podcast/episodes/{{ post.audio_file }}" 
                 {% if post.file_size %}length="{{ post.file_size }}"{% endif %}
                 type="audio/mpeg"/>
      {% endif %}
      {% if post.duration %}
      <itunes:duration>{{ post.duration }}</itunes:duration>
      {% endif %}
      <itunes:explicit>false</itunes:explicit>
      {% if post.episode %}
      <itunes:episode>{{ post.episode }}</itunes:episode>
      {% endif %}
      {% if post.season %}
      <itunes:season>{{ post.season }}</itunes:season>
      {% endif %}
      <itunes:episodeType>full</itunes:episodeType>
      {% if post.keywords %}
      <itunes:keywords>{{ post.keywords | join: ',' }}</itunes:keywords>
      {% endif %}
    </item>
    {% endif %}
    {% endfor %}
  </channel>
</rss>
